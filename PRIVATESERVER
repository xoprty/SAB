-- Функция поиска малозаселенного сервера
local function TeleportToSmallServer()
    ServerButton.Text = "SEARCHING..."
    ServerButton.TextColor3 = Color3.fromRGB(255, 150, 0)
    
    local placeId = game.PlaceId
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and result then
        local decodeSuccess, serverData = pcall(function()
            return HttpService:JSONDecode(result)
        end)
        
        if decodeSuccess and serverData and serverData.data then
            local targetServerId = nil
            local currentJobId = game.JobId
            
            -- Поиск оптимального сервера (где меньше всего людей, но не 0 и не текущий)
            for _, server in ipairs(serverData.data) do
                if server.id ~= currentJobId and tonumber(server.playing) < tonumber(server.maxPlayers) then
                    targetServerId = server.id
                    break
                end
            end
            
            if targetServerId then
                ServerButton.Text = "TELEPORTING..."
                ServerButton.TextColor3 = Color3.fromRGB(0, 255, 0)
                task.wait(0.5)
                pcall(function()
                    TeleportService:TeleportToPlaceInstance(placeId, targetServerId, LocalPlayer)
                end)
            else
                ServerButton.Text = "NOT FOUND"
                ServerButton.TextColor3 = Color3.fromRGB(255, 0, 0)
                task.wait(1.5)
                ServerButton.Text = "PRIVATE SERVER"
                ServerButton.TextColor3 = Color3.fromRGB(0, 255, 150)
            end
        end
    else
        ServerButton.Text = "HTTP ERROR"
        ServerButton.TextColor3 = Color3.fromRGB(255, 0, 0)
        task.wait(1.5)
        ServerButton.Text = "PRIVATE SERVER"
        ServerButton.TextColor3 = Color3.fromRGB(0, 255, 150)
    end
end

ServerButton.MouseButton1Click:Connect(TeleportToSmallServer)
