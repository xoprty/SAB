local function TeleportToSmallServer()
    ServerButton.Text = "SCANNING..."
    ServerButton.TextColor3 = Color3.fromRGB(255, 150, 0)
    
    local placeId = game.PlaceId
    -- Запрос списка публичных серверов с сортировкой по возрастанию
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and result then
        local decodeSuccess, serverData = pcall(function()
            return HttpService:JSONDecode(result)
        end)
        
        if decodeSuccess and serverData and serverData.data then
            local targetServerId = nil
            local currentJobId = game.JobId
            
            -- Жесткий перебор: ищем первый узел, где игроков строго <= 1
            for _, server in ipairs(serverData.data) do
                local playerCount = tonumber(server.playing)
                if server.id ~= currentJobId and playerCount and playerCount <= 1 then
                    targetServerId = server.id
                    break
                end
            end
            
            if targetServerId then
                ServerButton.Text = "FOUND! GOING..."
                ServerButton.TextColor3 = Color3.fromRGB(0, 255, 0)
                task.wait(0.3)
                pcall(function()
                    TeleportService:TeleportToPlaceInstance(placeId, targetServerId, LocalPlayer)
                end)
            else
                -- Если по умолчанию Asc выдал плохой чанк данных, пробуем инвертировать поиск
                ServerButton.Text = "TRYING ALT PAGE..."
                local altUrl = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
                local altSuccess, altResult = pcall(function() return game:HttpGet(altUrl) end)
                
                if altSuccess and altResult then
                    local altDecode, altData = pcall(function() return HttpService:JSONDecode(altResult) end)
                    if altDecode and altData.data then
                        for _, server in ipairs(altData.data) do
                            local playerCount = tonumber(server.playing)
                            if server.id ~= currentJobId and playerCount and playerCount <= 1 then
                                targetServerId = server.id
                                break
                            end
                        end
                    end
                end
                
                if targetServerId then
                    ServerButton.Text = "FOUND! GOING..."
                    ServerButton.TextColor3 = Color3.fromRGB(0, 255, 0)
                    task.wait(0.3)
                    pcall(function()
                        TeleportService:TeleportToPlaceInstance(placeId, targetServerId, LocalPlayer)
                    end)
                else
                    ServerButton.Text = "0-1 PLR NOT FOUND"
                    ServerButton.TextColor3 = Color3.fromRGB(255, 0, 0)
                    task.wait(1.5)
                    ServerButton.Text = "PRIVATE SERVER"
                    ServerButton.TextColor3 = Color3.fromRGB(0, 255, 150)
                end
            end
        end
    else
        ServerButton.Text = "API TIMEOUT"
        ServerButton.TextColor3 = Color3.fromRGB(255, 0, 0)
        task.wait(1.5)
        ServerButton.Text = "PRIVATE SERVER"
        ServerButton.TextColor3 = Color3.fromRGB(0, 255, 150)
    end
end

ServerButton.MouseButton1Click:Connect(TeleportToSmallServer)
