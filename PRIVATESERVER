        if States.EspLock then
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if States.EspLock and obj:IsA("BasePart") then
                    local timerText = findTimerText(obj)
                    if timerText then
                        CreateESP(obj, timerText, Color3.fromRGB(255, 170, 0), "EspLock", false)
                    end
                end
            end
        end
    end
end)

