local function GetClosestPlayerToMe()
    local Target = nil
    local MinDistance = math.huge
    local MyChar = LocalPlayer.Character
    local MyRoot = MyChar and MyChar:FindFirstChild("HumanoidRootPart")
    
    if MyRoot then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChildOfClass("Humanoid") then
                if player.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
                    local Root = player.Character.HumanoidRootPart
                    local Distance = (Root.Position - MyRoot.Position).Magnitude
                    if Distance < MinDistance then
                        MinDistance = Distance
                        Target = player.Character
                    end
                end
            end
        end
    end
    return Target, MinDistance
end

-- Функция для поиска топового Brainrot игрока
local function GetTopBrainrotPlayer()
    local TopPlayer = nil
    local MaxValue = -1
    local IncomeName = "Income"
    
    for _, player in ipairs(Players:GetPlayers()) do
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            local targetStat = nil
            for _, stat in ipairs(leaderstats:GetChildren()) do
                local nameLower = stat.Name:lower()
                if nameLower:find("brainrot") or nameLower:find("income") or nameLower:find("points") or nameLower:find("доход") or stat:IsA("IntValue") or stat:IsA("NumberValue") then
                    if not targetStat or nameLower:find("brainrot") or nameLower:find("income") then
                        targetStat = stat
                    end
                end
            end
            
            if targetStat and targetStat.Value > MaxValue then
                MaxValue = targetStat.Value
                TopPlayer = player
                IncomeName = targetStat.Name
            end
        end
    end
    return TopPlayer, MaxValue, IncomeName
end

local LastJump = 0
UserInputService.JumpRequest:Connect(function()
    if States.InfJump and tick() - LastJump > 0.15 then
        local Character = LocalPlayer.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        
        if Root and Humanoid then
            LastJump = tick()
            Root.Velocity = Vector3.new(Root.Velocity.X, States.JumpBoost and States.JumpValue or 50, Root.Velocity.Z)
        end
    end
end)

RunService.PostSimulation:Connect(function()
    local Character = LocalPlayer.Character
    if Character then
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            if States.SpeedBoost then
                Humanoid.WalkSpeed = States.SpeedValue
            end
            if States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = States.JumpValue
                Humanoid.UseJumpPower = true
            elseif not States.JumpBoost and not States.InfJump then
                Humanoid.JumpPower = 50
            end
        end
    end
end)

-- Усовершенствованная доводка AUTOAIM WEB (перехват клика рядом и мгновенное наведение луча на игрока)
local IsRedirecting = false
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if States.AutoAimWeb and input.UserInputType == Enum.UserInputType.MouseButton1 then
        local Character = LocalPlayer.Character
        if Character then
            local Tool = Character:FindFirstChild("Web Slinger") or Character:FindFirstChild("WebSlinger")
            if Tool and not IsRedirecting then
                local TargetChar, Distance = GetClosestPlayerToMe()
                if TargetChar then
                    local TargetRoot = TargetChar:FindFirstChild("HumanoidRootPart")
                    if TargetRoot then
                        IsRedirecting = true
                        
                        -- Активация инструмента с подменой аргументов
                        Tool:Activate()
                        
                        local Remote = Tool:FindFirstChildOfClass("RemoteEvent") or Tool:FindFirstChildOfClass("RemoteFunction")
                        if Remote then
                            pcall(function()
                                if Remote:IsA("RemoteEvent") then
                                    -- Посылаем координаты врага серверу вместо оригинальной позиции мыши
                                    Remote:FireServer(TargetRoot.Position, TargetChar)
                                    Remote:FireServer(TargetRoot)
                                else
                                    Remote:InvokeServer(TargetRoot.Position, TargetChar)
                                    Remote:InvokeServer(TargetRoot)
                                end
                            end)
                        end
                        
                        task.wait(0.05)
                        IsRedirecting = false
                    end
                end
            end
        end
    end
end)

