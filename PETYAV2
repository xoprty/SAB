local function CreateESP(object, text, color, stateKey, isPlayer)
    if ESP_Storage[object] then 
        return 
    end
    
    local Box = Instance.new("Highlight")
    Box.Adornee = object
    Box.FillColor = color
    Box.FillTransparency = 0.6
    Box.OutlineColor = Color3.fromRGB(255, 255, 255)
    Box.OutlineTransparency = 0.2
    Box.Parent = ScreenGui
    
    local Billboard = Instance.new("BillboardGui")
    Billboard.Adornee = isPlayer and object:FindFirstChild("HumanoidRootPart") or object
    Billboard.Size = UDim2.new(0, 200, 0, 50)
    Billboard.AlwaysOnTop = true
    Billboard.StudsOffset = Vector3.new(0, 3, 0)
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = color
    Label.Font = Enum.Font.Arcade
    Label.TextSize = 14
    Label.Parent = Billboard
    Billboard.Parent = ScreenGui
    
    ESP_Storage[object] = {Box, Billboard, Label}
    
    task.spawn(function()
        while object and object.Parent and States[stateKey] do 
            if stateKey == "EspLock" then
                -- Парсинг реального текста таймера с объектов базы данных
                local realTimerText = "0s"
                local parentModel = object.Parent
                if parentModel then
                    for _, child in ipairs(parentModel:GetDescendants()) do
                        if child:IsA("TextLabel") and (child.Text:lower():find("lock") or child.Text:find("s") or child.Text:match("%d+")) then
                            realTimerText = child.Text:gsub("\n", " ")
                            break
                        elseif child:IsA("TextMesh") and (child.Text:lower():find("lock") or child.Text:find("s") or child.Text:match("%d+")) then
                            realTimerText = child.Text:gsub("\n", " ")
                            break
                        end
                    end
                end
                Label.Text = realTimerText
            end
            task.wait(0.2) 
        end
        Box:Destroy()
        Billboard:Destroy()
        ESP_Storage[object] = nil
    end)
end

