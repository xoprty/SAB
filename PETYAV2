-- Однократное точное наведение и выстрел Web Slinger
local function TriggerAutoWeb()
    local Character = LocalPlayer.Character
    if not Character then return end
    
    local Tool = LocalPlayer.Backpack:FindFirstChild("Web Slinger") or LocalPlayer.Backpack:FindFirstChild("WebSlinger") or Character:FindFirstChild("Web Slinger") or Character:FindFirstChild("WebSlinger")
    if Tool then
        Tool.Parent = Character
        task.wait(0.02)
        local TargetChar = GetClosestPlayerToMe()
        local TargetRoot = TargetChar and TargetChar:FindFirstChild("HumanoidRootPart")
        if TargetRoot then
            -- Фиксация вектора атаки
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, TargetRoot.Position)
            Tool:Activate()
            -- Дублирование триггера для сетевых инструментов
            local Remote = Tool:FindFirstChildOfClass("RemoteEvent") or Tool:FindFirstChildOfClass("RemoteFunction")
            if Remote then
                pcall(function() Remote:FireServer(TargetRoot.Position) end)
                pcall(function() Remote:FireServer(TargetRoot) end)
            end
        end
    end
end

-- Сетевой спам-запрос на покупку ловушки в магазине
local function TriggerBuyTrap()
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    for _, descendant in ipairs(ReplicatedStorage:GetDescendants()) do
        if descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction") then
            local name = descendant.Name:lower()
            if name:find("buy") or name:find("shop") or name:find("purchase") or name:find("item") or name:find("trap") then
                pcall(function()
                    if descendant:IsA("RemoteEvent") then
                        descendant:FireServer("Trap")
                        descendant:FireServer("trap")
                    else
                        descendant:InvokeServer("Trap")
                        descendant:InvokeServer("trap")
                    end
                end)
            end
        end
    end
end

-- Автоматический цикл преследования и атаки битой (AUTOBAT)
task.spawn(function()
    while true do
        task.wait()
        if States.AutoBat then
            local Character = LocalPlayer.Character
            local MyRoot = Character and Character:FindFirstChild("HumanoidRootPart")
            if Character and MyRoot then
                local Tool = LocalPlayer.Backpack:FindFirstChild("Bat") or LocalPlayer.Backpack:FindFirstChild("BAT") or Character:FindFirstChild("Bat") or Character:FindFirstChild("BAT")
                if Tool then
                    Tool.Parent = Character
                end
                
                local TargetChar, Distance = GetClosestPlayerToMe()
                if TargetChar and TargetChar:FindFirstChild("HumanoidRootPart") then
                    local TargetRoot = TargetChar.HumanoidRootPart
                    -- Сближение вплотную к хитбоксу цели
                    MyRoot.CFrame = TargetRoot.CFrame * CFrame.new(0, 0, 2)
                    
                    local CurrentTool = Character:FindFirstChild("Bat") or Character:FindFirstChild("BAT")
                    if CurrentTool then
                        CurrentTool:Activate()
                    end
                end
            end
        end
    end
end)

